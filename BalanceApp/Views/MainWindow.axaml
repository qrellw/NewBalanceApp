<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:BalanceApp.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:icons="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
        mc:Ignorable="d" d:DesignWidth="1000" d:DesignHeight="600"
        x:Class="BalanceApp.Views.MainWindow"
        x:DataType="vm:MainViewModel"
        Icon="/Assets/avalonia-logo.ico"
        Title="BalanceApp"
        Background="{StaticResource AppBackgroundBrush}"
        ExtendClientAreaToDecorationsHint="True"
        ExtendClientAreaChromeHints="PreferSystemChrome"
        ExtendClientAreaTitleBarHeightHint="40">

    <Design.DataContext>
        <vm:MainViewModel/>
    </Design.DataContext>

    <!-- Main Container -->
    <Grid RowDefinitions="Auto, *">
        <!-- Custom Title Bar Background (Solid) -->
        <Border Grid.Row="0" Height="40" Background="Transparent" IsHitTestVisible="False"/>

        <SplitView Grid.Row="1" Grid.RowSpan="1" Margin="0,-40,0,0"
                   IsPaneOpen="{Binding IsPaneOpen}"
                   OpenPaneLength="260"
                   CompactPaneLength="56"
                   DisplayMode="CompactInline"
                   Background="{StaticResource AppBackgroundBrush}"
                   PaneBackground="#F0F0F0"> 
            
            <SplitView.Pane>
                <Grid RowDefinitions="40, *">
                    <!-- Title Bar Drag Region in Pane -->
                    <Border Grid.Row="0" Background="Transparent" />
                    
                    <StackPanel Grid.Row="1" Spacing="5" Margin="5">
                        <!-- Toggle Button -->
                        <Button Command="{Binding TogglePaneCommand}"
                                HorizontalAlignment="Left"
                                Width="46" Height="40"
                                Background="Transparent"
                                BorderThickness="0"
                                Margin="0,0,0,10">
                            <icons:MaterialIcon Kind="Menu" Width="20" Height="20" Foreground="#505050"/>
                        </Button>

                        <!-- Patient Menu Item -->
                        <Button Command="{Binding GoToPatientsCommand}"
                                HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Left"
                                Height="40"
                                Padding="12,0"
                                Background="Transparent"
                                BorderThickness="0"
                                CornerRadius="4">
                            <Grid ColumnDefinitions="30, *">
                                <icons:MaterialIcon Kind="AccountOutline" Width="20" Height="20" Foreground="#505050" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="1" Text="Bệnh Nhân" VerticalAlignment="Center" Margin="10,0,0,0"
                                           IsVisible="{Binding IsPaneOpen}" FontWeight="Medium" Foreground="#333"/>
                            </Grid>
                        </Button>

                        <!-- Measurement Menu Item -->
                        <Button Command="{Binding GoToMeasurementCommand}"
                                HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Left"
                                Height="40"
                                Padding="12,0"
                                Background="Transparent"
                                BorderThickness="0"
                                CornerRadius="4">
                            <Grid ColumnDefinitions="30, *">
                                <icons:MaterialIcon Kind="ChartBoxOutline" Width="20" Height="20" Foreground="#505050" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="1" Text="Đo Đạc &amp; Đồ Thị" VerticalAlignment="Center" Margin="10,0,0,0"
                                           IsVisible="{Binding IsPaneOpen}" FontWeight="Medium" Foreground="#333"/>
                            </Grid>
                        </Button>
                    </StackPanel>
                </Grid>
            </SplitView.Pane>

            <SplitView.Content>
                 <!-- Add Top Padding for TitleBar -->
                <TransitioningContentControl Content="{Binding CurrentView}" Margin="0,40,0,0"/>
            </SplitView.Content>
        </SplitView>
        
        <!-- Window Title (Centered) -->
        <TextBlock Grid.Row="0" Text="{Binding $parent[Window].Title}" 
                   VerticalAlignment="Center" HorizontalAlignment="Center" 
                   IsHitTestVisible="False"
                   FontSize="12"
                   Foreground="#808080"/>
    </Grid>

</Window>
