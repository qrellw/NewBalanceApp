<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:BalanceApp.ViewModels"
             xmlns:models="using:BalanceApp.Models"
             xmlns:icons="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="BalanceApp.Views.PatientView"
             x:DataType="vm:PatientViewModel">
  
  <Grid Classes="Page" RowDefinitions="Auto, Auto, *">
      
      <!-- Header -->
      <Grid Grid.Row="0" ColumnDefinitions="*, Auto" Margin="0,0,0,20">
          <TextBlock Text="{Binding Title}" Classes="PageHeader" Margin="0" VerticalAlignment="Center"/>
          
          <Button Grid.Column="1" Click="OpenAddPatient_Click" Classes="Accent" Padding="12,8">
              <StackPanel Orientation="Horizontal" Spacing="8">
                  <icons:MaterialIcon Kind="Plus" Foreground="White" Width="16" Height="16"/>
                  <TextBlock Text="Thêm Bệnh Nhân" FontWeight="SemiBold"/>
              </StackPanel>
          </Button>
      </Grid>
      
      <!-- Search Section (Card) -->
      <Border Grid.Row="1" Classes="Card">
          <StackPanel Spacing="10">
              <TextBlock Text="Tìm Kiếm" Classes="SectionHeader"/>
              <TextBox Text="{Binding SearchText}" Watermark="Nhập tên hoặc số điện thoại..." Width="400" HorizontalAlignment="Left"/>
          </StackPanel>
      </Border>

      <!-- DataGrid Section (Card) -->
      <Border Grid.Row="2" Classes="Card" Padding="0"> <!-- Remove padding for Grid to sit flush if desired, or keep -->
          <Grid RowDefinitions="Auto, *">
              <TextBlock Text="Danh Sách Bệnh Nhân" Classes="SectionHeader" Margin="16,16,0,10"/>
              
              <DataGrid Grid.Row="1" Margin="0,10,0,0" ItemsSource="{Binding Patients}"
                        SelectedItem="{Binding SelectedPatientInGrid}"
                        IsReadOnly="True"
                        GridLinesVisibility="Horizontal"
                        BorderThickness="0"
                        Background="White"
                        HeadersVisibility="Column">
                  <DataGrid.Styles>
                      <Style Selector="DataGridColumnHeader">
                          <Setter Property="Background" Value="Transparent"/>
                          <Setter Property="FontWeight" Value="SemiBold"/>
                          <Setter Property="Foreground" Value="#606060"/>
                          <Setter Property="Padding" Value="16,10"/>
                      </Style>
                      <Style Selector="DataGridRow">
                         <Setter Property="Padding" Value="10"/> 
                      </Style>
                  </DataGrid.Styles>
                  <DataGrid.Columns>
                      <DataGridTextColumn Header="Mã BA" Binding="{Binding MedicalId}" Width="Auto"/>
                      <DataGridTextColumn Header="Họ và Tên" Binding="{Binding FullName}" Width="*"/>
                      <DataGridTextColumn Header="Địa Chỉ" Binding="{Binding Address}" Width="200"/>
                      <DataGridTextColumn Header="Ngày Sinh" Binding="{Binding DateOfBirth, StringFormat={}{0:dd/MM/yyyy}}" Width="Auto"/>
                      <DataGridTextColumn Header="Giới Tính" Binding="{Binding Gender}" Width="Auto"/>
                      <DataGridTextColumn Header="SĐT" Binding="{Binding PhoneNumber}" Width="Auto"/>
                      
                      <DataGridTemplateColumn Header="Hành Động" Width="Auto">
                          <DataGridTemplateColumn.CellTemplate>
                              <DataTemplate DataType="models:Patient">
                                  <StackPanel Orientation="Horizontal" Spacing="8" Margin="8,4">
                                      <Button Content="Chọn" 
                                              Command="{Binding $parent[UserControl].((vm:PatientViewModel)DataContext).SelectPatientCommand}"
                                              CommandParameter="{Binding}"
                                              Padding="12,6"
                                              Background="#E8F5E9" Foreground="#2E7D32" BorderThickness="0" CornerRadius="4"/>
                                      
                                      <Button Command="{Binding $parent[UserControl].((vm:PatientViewModel)DataContext).ViewHistoryCommand}"
                                              CommandParameter="{Binding}"
                                              Content="Lịch Sử" Background="#E3F2FD" Foreground="#1565C0" BorderThickness="0" Padding="12,6" CornerRadius="4"/>
                                              
                                      <Button Command="{Binding $parent[UserControl].((vm:PatientViewModel)DataContext).DeletePatientCommand}"
                                              CommandParameter="{Binding}"
                                              Content="Xóa" Background="Transparent" Foreground="#C62828" BorderThickness="0" Padding="8,6"/>
                                  </StackPanel>
                              </DataTemplate>
                          </DataGridTemplateColumn.CellTemplate>
                      </DataGridTemplateColumn>
                  </DataGrid.Columns>
              </DataGrid>
          </Grid>
      </Border>
  </Grid>
</UserControl>
