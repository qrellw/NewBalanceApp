<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:BalanceApp.ViewModels"
             xmlns:sp="clr-namespace:ScottPlot.Avalonia;assembly=ScottPlot.Avalonia"
             xmlns:icons="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
             mc:Ignorable="d" d:DesignWidth="1000" d:DesignHeight="600"
             x:Class="BalanceApp.Views.HistoryView"
             x:DataType="vm:HistoryViewModel">

    <Grid Classes="Page" RowDefinitions="Auto, *">
        <!-- Header -->
        <StackPanel Orientation="Horizontal" Spacing="20" Margin="0,0,0,20">
             <Button Command="{Binding GoBackCommand}" Background="Transparent" BorderThickness="0" Padding="0">
                 <icons:MaterialIcon Kind="ArrowLeft" Width="24" Height="24" Foreground="#333"/>
             </Button>
             <TextBlock Text="{Binding PatientName, StringFormat='Lịch Sử: {0}'}" Classes="PageHeader" Margin="0" VerticalAlignment="Center"/>
        </StackPanel>

        <!-- Content Split View -->
        <Grid Grid.Row="1" ColumnDefinitions="300, *">
            
            <!-- Left: Session List (Card) -->
            <Border Grid.Column="0" Classes="Card" Margin="0,0,16,0" Padding="0">
                <Grid RowDefinitions="Auto, *">
                    <TextBlock Text="Các Buổi Đo" Classes="SectionHeader" Margin="16,16,0,10"/>
                    <ListBox Grid.Row="1" ItemsSource="{Binding Sessions}" SelectedItem="{Binding SelectedSession}" Background="Transparent">
                        <ListBox.Styles>
                            <Style Selector="ListBoxItem">
                                <Setter Property="Padding" Value="16,12"/>
                                <Setter Property="CornerRadius" Value="4"/>
                                <Setter Property="Margin" Value="8,2"/>
                            </Style>
                        </ListBox.Styles>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid ColumnDefinitions="*, Auto" Margin="0">
                                    <StackPanel Grid.Column="0" Spacing="4" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding TestDate, StringFormat='{}{0:dd/MM/yyyy HH:mm}'}" FontWeight="SemiBold"/>
                                        <TextBlock Text="{Binding Notes}" FontSize="12" Foreground="#808080" TextTrimming="CharacterEllipsis"/>
                                    </StackPanel>
                                    
                                    <Button Grid.Column="1" 
                                            Classes="delete-btn"
                                            Background="Transparent" 
                                            BorderThickness="0"
                                            Padding="8"
                                            VerticalAlignment="Center"
                                            Command="{Binding $parent[UserControl].((vm:HistoryViewModel)DataContext).DeleteSessionCommand}"
                                            CommandParameter="{Binding .}">
                                        <icons:MaterialIcon Kind="TrashCanOutline" Width="20" Height="20" Foreground="#D32F2F"/>
                                    </Button>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>

            <!-- Right: Graph Detail (Card) -->
            <Border Grid.Column="1" Classes="Card">
                <Grid RowDefinitions="Auto, *">
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,16">
                        <StackPanel Orientation="Horizontal" Spacing="20">
                            <TextBlock Text="Chi Tiết Buổi Đo" Classes="SectionHeader" Margin="0"/>
                            <TextBlock Text="{Binding SelectedSession.TestDate, StringFormat='Ngày: {0:dd/MM/yyyy HH:mm}'}" 
                                       VerticalAlignment="Bottom" Foreground="#606060"
                                       IsVisible="{Binding SelectedSession, Converter={x:Static ObjectConverters.IsNotNull}}"/>
                        </StackPanel>
                        
                        <!-- Spacer -->
                        <Panel Width="NaN" HorizontalAlignment="Stretch"/>
                    </StackPanel>

                    <sp:AvaPlot Name="HistoryPlot" Grid.Row="1"/>
                </Grid>
            </Border>
        </Grid>
    </Grid>

    <UserControl.Styles>
        <!-- Hide Delete Button by default -->
        <Style Selector="ListBoxItem .delete-btn" x:SetterTargetType="Button">
            <Setter Property="IsVisible" Value="False"/>
        </Style>
        <!-- Show Delete Button on Hover or Selection -->
        <Style Selector="ListBoxItem:pointerover .delete-btn" x:SetterTargetType="Button">
            <Setter Property="IsVisible" Value="True"/>
        </Style>
        <Style Selector="ListBoxItem:selected .delete-btn" x:SetterTargetType="Button">
            <Setter Property="IsVisible" Value="True"/>
        </Style>
    </UserControl.Styles>
</UserControl>
