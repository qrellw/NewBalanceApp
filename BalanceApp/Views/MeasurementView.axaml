<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:BalanceApp.ViewModels"
             xmlns:sp="clr-namespace:ScottPlot.Avalonia;assembly=ScottPlot.Avalonia"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="BalanceApp.Views.MeasurementView"
             x:DataType="vm:MeasurementViewModel">
  
  <Grid Classes="Page" RowDefinitions="Auto, *">
      
      <!-- Control Bar (Patient + Actions + Status) -->
      <Border Grid.Row="0" Classes="Card" Margin="0,0,0,12" Padding="12">
          <Grid ColumnDefinitions="Auto, *, Auto">
              <!-- Left: Patient Info -->
              <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="16" VerticalAlignment="Center">
                  <StackPanel Spacing="2">
                      <TextBlock Text="Bệnh Nhân" Classes="SectionHeader" Margin="0" FontSize="12"/>
                      <TextBlock Text="{Binding MainContext.SelectedPatientName, TargetNullValue='Chưa chọn'}" 
                                 FontSize="16" FontWeight="SemiBold" Foreground="{StaticResource AccentBrush}"/>
                  </StackPanel>
                  
                  <!-- Separator -->
                  <Border Width="1" Height="24" Background="#E0E0E0" Margin="8,0"/>

                  <!-- Actions (Moved here) -->
                  <StackPanel Orientation="Horizontal" Spacing="8">
                       <Button Command="{Binding StartStopMeasurementCommand}" 
                               Content="{Binding ActionButtonText}"
                               Classes="Accent" Padding="20,6"
                               IsEnabled="{Binding CanStart}"/>
                       
                       <Button Command="{Binding ToggleSimulationCommand}"
                               Content="Giả lập"
                               Background="Transparent" BorderBrush="#D0D0D0" BorderThickness="1" CornerRadius="4" Padding="12,6"/>
                  </StackPanel>
              </StackPanel>

              <!-- Right: Device Status -->
              <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                   <StackPanel Spacing="2" HorizontalAlignment="Right">
                       <TextBlock Text="Thiết Bị" Classes="SectionHeader" Margin="0" FontSize="12" HorizontalAlignment="Right"/>
                       <StackPanel Orientation="Horizontal" Spacing="6">
                           <TextBlock Text="{Binding ConnectionStatus}" Foreground="#4CAF50" FontWeight="Medium" FontSize="14"/>
                           <!-- Indicator -->
                           <Border Width="10" Height="10" CornerRadius="5" Margin="0,5,0,0"
                                   Classes.connected="{Binding IsConnected}">
                               <Border.Styles>
                                   <Style Selector="Border">
                                       <Setter Property="Background" Value="#F44336"/> 
                                   </Style>
                                   <Style Selector="Border.connected">
                                       <Setter Property="Background" Value="#4CAF50"/>
                                   </Style>
                               </Border.Styles>
                           </Border>
                       </StackPanel>
                   </StackPanel>
                   
                   <Button Command="{Binding ScanDevicesCommand}"
                           Content="Kết nối" FontSize="11" Padding="8,4" 
                           IsVisible="{Binding !IsConnected}" Classes="Accent" VerticalAlignment="Center"/>
              </StackPanel>
          </Grid>
      </Border>
      
      <!-- Main Content (Graph Only) -->
      <Border Grid.Row="1" Classes="Card" Padding="0">
          <Grid Margin="16">
              <sp:AvaPlot Name="BalancePlot" />
          </Grid>
      </Border>
  </Grid>
</UserControl>
