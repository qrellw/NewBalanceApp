<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:BalanceApp.ViewModels"
             xmlns:sp="clr-namespace:ScottPlot.Avalonia;assembly=ScottPlot.Avalonia"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="BalanceApp.Views.MeasurementView"
             x:DataType="vm:MeasurementViewModel">
  
  <Grid RowDefinitions="Auto, Auto, *">
      
      <!-- Top Bar: Patient Info -->
      <Border Grid.Row="0" Background="#E3F2FD" Padding="20" BorderBrush="#2196F3" BorderThickness="0,0,0,2">
          <Grid ColumnDefinitions="Auto, *, Auto">
              <StackPanel Orientation="Vertical">
                  <TextBlock Text="ĐANG ĐO CHO BỆNH NHÂN:" FontSize="12" Foreground="Gray"/>
                  <TextBlock Text="{Binding MainContext.SelectedPatientName}" FontSize="20" FontWeight="Bold" Foreground="#0D47A1"/>
              </StackPanel>

              <TextBlock Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="20,0"
                         Text="{Binding ConnectionStatus}" Foreground="Green" FontWeight="SemiBold"/>
              
              
              <!-- Sensor Status (Simplified) -->
              <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="10">
                  <!-- Only show Retry button if failed -->
                  <Button Command="{Binding ScanDevicesCommand}" 
                          Content="Kết Nối Lại"
                          IsVisible="{Binding !IsConnected}"
                          Classes="accent"/>
                  
                  <!-- Connection Indicator -->
                  <Border CornerRadius="10" Width="20" Height="20" Margin="10,0,0,0"
                          Classes.connected="{Binding IsConnected}"
                          ToolTip.Tip="{Binding ConnectionStatus}">
                      <Border.Styles>
                          <Style Selector="Border">
                              <Setter Property="Background" Value="Red"/> <!-- Default/Disconnected -->
                          </Style>
                          <Style Selector="Border.connected">
                              <Setter Property="Background" Value="LimeGreen"/>
                          </Style>
                      </Border.Styles>
                  </Border>
              </StackPanel>
          </Grid>
      </Border>
      
      <!-- Action Bar -->
      <Border Grid.Row="1" Background="#F5F5F5" Padding="10">
          <StackPanel Orientation="Horizontal" Spacing="10">
               <Button Command="{Binding StartStopMeasurementCommand}" 
                          Content="{Binding ActionButtonText}"
                          Background="#F44336" Foreground="White" FontWeight="Bold" Padding="20,10"
                          IsEnabled="{Binding CanStart}"/>
               
               <Button Command="{Binding ToggleSimulationCommand}"
                       Content="Giả Lập"
                       Classes="outline"/>
          </StackPanel>
      </Border>

      <!-- Main Graph Area -->
      <Grid Grid.Row="2" Background="White" Margin="10">
          <sp:AvaPlot Name="BalancePlot" />
      </Grid>
  </Grid>
</UserControl>
